---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = "Thomas Ptashnik — Researcher, Teacher, and AI Coach at Providence College.",
  image = "/Faculty%20headshot.jpg",
} = Astro.props;

const { pathname } = Astro.url;
const canonicalURL = new URL(pathname, Astro.site);
const ogImageURL = new URL(image, Astro.site);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Thomas Ptashnik",
  "jobTitle": "Assistant Professor of Management",
  "worksFor": {
    "@type": "Organization",
    "name": "Providence College",
    "url": "https://www.providence.edu"
  },
  "url": "https://www.thomas-ptashnik.com",
  "sameAs": [
    "https://scholar.google.com/citations?user=8Cn6E4QAAAAJ&hl=en",
    "https://www.linkedin.com/in/thomas-ptashnik",
    "https://www.thenoticingproject.org"
  ],
  "knowsAbout": [
    "Organizational Behavior",
    "Human Resource Management",
    "Work-Family Balance",
    "Employee Well-being",
    "Prosocial Motivation"
  ]
};

function isActive(path: string) {
  if (path === "/") return pathname === "/";
  return pathname.startsWith(path);
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} — Thomas Ptashnik`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:site_name" content="Thomas Ptashnik" />

    <!-- Twitter / X card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} — Thomas Ptashnik`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <title>{title} — Thomas Ptashnik</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <nav>
      <div class="container nav-inner">
        <a href="/" class="nav-logo">Thomas Ptashnik</a>
        <ul class="nav-links">
          <li><a href="/research" class:list={{ active: isActive("/research") }}>Research</a></li>
          <li><a href="/teaching" class:list={{ active: isActive("/teaching") }}>Teaching</a></li>
          <li><a href="/consulting" class:list={{ active: isActive("/consulting") }}>Work with me</a></li>
          <li><a href="/press" class:list={{ active: isActive("/press") }}>Press</a></li>
        </ul>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer>
      <div class="container footer-inner">
        <p class="footer-left">© {new Date().getFullYear()} Thomas Ptashnik</p>
        <div class="footer-links">
          <a href="https://scholar.google.com/citations?user=8Cn6E4QAAAAJ&hl=en" target="_blank" rel="noopener">Google Scholar</a>
          <a href="https://www.linkedin.com/in/thomas-ptashnik" target="_blank" rel="noopener">LinkedIn</a>
          <a href="https://www.thenoticingproject.org" target="_blank" rel="noopener">The Noticing Project</a>
          <a href="/contact">Contact</a>
        </div>
      </div>
    </footer>
  </body>
</html>

