---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home" description="Thomas Ptashnik — Assistant Professor at Providence College. Researcher, teacher, and AI coach.">

  <!-- ── Hero ──────────────────────────────────────── -->
  <section class="hero">
    <div class="container hero-inner">

      <div class="hero-photo-wrap">
        <img src="/thomas-image.jpeg" alt="Thomas Ptashnik" class="headshot-img" />
      </div>

      <div class="hero-text">
        <p class="hero-label">Assistant Professor · Providence College</p>
        <h1 class="hero-name">Thomas Ptashnik</h1>
        <p class="hero-tagline">
          I study what makes work meaningful — especially for working parents.<br />
          I help students build careers they love.<br />
          I coach professionals on AI.
        </p>
        <div class="hero-ctas">
          <a href="/cv.docx" download class="btn btn-primary">Download CV</a>
          <a href="/research" class="btn btn-outline">Research</a>
          <a href="/teaching" class="btn btn-outline">Teaching</a>
          <a href="/consulting" class="btn btn-outline">Work with me</a>
        </div>
      </div>

    </div>
  </section>

  <!-- ── Entry cards ───────────────────────────────── -->
  <section class="entries section">
    <div class="container">
      <div class="entry-grid">

        <a href="/research" class="entry-card">
          <span class="entry-num">01</span>
          <h2 class="entry-title">Research</h2>
          <p class="entry-desc">
            Publications in <em>Psychological Bulletin</em> and the <em>Journal of Applied Psychology</em>,
            with an active pipeline on well-being, working parents, and organizational behavior.
          </p>
          <span class="entry-link">Explore research →</span>
        </a>

        <a href="/teaching" class="entry-card">
          <span class="entry-num">02</span>
          <h2 class="entry-title">Teaching</h2>
          <p class="entry-desc">
            Courses in Human Resource Management and Managing &amp; Organizing at Providence College,
            plus The Noticing Project — an educational initiative for high school and college students.
          </p>
          <span class="entry-link">See courses →</span>
        </a>

        <a href="/consulting" class="entry-card">
          <span class="entry-num">03</span>
          <h2 class="entry-title">Consulting</h2>
          <p class="entry-desc">
            1:1 coaching for professionals navigating the shift to AI — from building agent workflows
            to developing the tools and sites you need to move faster.
          </p>
          <span class="entry-link">Work with me →</span>
        </a>

      </div>
    </div>
  </section>

</Layout>

<style>
  /* ── Hero ─────────────────────────────── */
  .hero {
    padding: 6rem 0 5rem;
    border-bottom: 1px solid var(--border);
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 400px 1fr;
    gap: 5rem;
    align-items: center;
  }

  .hero-photo-wrap {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .headshot-img {
    width: 380px;
    height: 380px;
    object-fit: cover;
    object-position: center top;
    border-radius: 50%;
  }

  .hero-label {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 1rem;
  }

  .hero-name {
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 5vw, 3.75rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
  }

  .hero-tagline {
    font-size: 1.05rem;
    line-height: 2;
    color: var(--muted);
    margin-bottom: 2.5rem;
    font-weight: 300;
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    align-items: center;
  }

  /* ── Entry cards ──────────────────────── */
  .entries {
    border-bottom: 1px solid var(--border);
  }

  .entry-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border: 1px solid var(--border);
  }

  .entry-card {
    display: flex;
    flex-direction: column;
    padding: 2.5rem;
    text-decoration: none;
    color: inherit;
    border-right: 1px solid var(--border);
    transition: background 0.2s;
    gap: 0.75rem;
  }

  .entry-card:last-child {
    border-right: none;
  }

  .entry-card:hover {
    background: var(--surface);
    text-decoration: none;
  }

  .entry-num {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: var(--muted);
  }

  .entry-title {
    font-family: var(--font-serif);
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--dark);
    margin-top: 0.25rem;
  }

  .entry-desc {
    font-size: 0.9rem;
    color: var(--muted);
    line-height: 1.7;
    flex: 1;
  }

  .entry-link {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--navy);
    margin-top: 0.5rem;
  }

  /* ── Responsive ───────────────────────── */
  @media (max-width: 960px) {
    .hero-inner {
      grid-template-columns: 320px 1fr;
      gap: 3rem;
    }
    .headshot-img {
      width: 300px;
      height: 300px;
    }
  }

  @media (max-width: 720px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .headshot-img {
      width: 240px;
      height: 240px;
    }
    .hero-text {
      text-align: center;
    }
    .hero-ctas {
      justify-content: center;
    }
  }

  @media (max-width: 640px) {
    .hero {
      padding: 3rem 0;
    }
    .entry-grid {
      grid-template-columns: 1fr;
    }
    .entry-card {
      border-right: none;
      border-bottom: 1px solid var(--border);
    }
    .entry-card:last-child {
      border-bottom: none;
    }
  }
</style>
