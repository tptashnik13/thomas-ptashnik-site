---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Press" description="Media coverage and press features for Thomas Ptashnik's research on working parents, well-being, and kindness at work.">

  <!-- ── Hero quote ─────────────────────────────────── -->
  <section class="press-hero">
    <div class="container press-hero-inner">
      <p class="press-hero-label">Fast Company</p>
      <blockquote class="press-hero-quote">
        "The assumption is, if you're being nice, you're not competitive,
        you do not perform well, and you do not advance in your career as much as others."
      </blockquote>
      <p class="press-hero-attr">Thomas Ptashnik · "Does being nice hurt your career?"</p>
    </div>
  </section>

  <!-- ── Coverage grid ──────────────────────────────── -->
  <section class="section">
    <div class="container">
      <p class="section-label">Media Coverage</p>

      <div class="press-grid">

        <!-- Featured: motherhood advantage (dual coverage) -->
        <div class="press-card press-card--featured">
          <div class="press-card-outlets">
            <span class="press-outlet">China Business Knowledge</span>
            <span class="press-divider">·</span>
            <span class="press-outlet">UNM News</span>
          </div>
          <h2 class="press-card-headline">The Motherhood Advantage</h2>
          <p class="press-card-body">
            Two outlets covered the same finding: rather than penalizing women for having children,
            new research reveals a <em>motherhood advantage</em> — parenthood can boost perceptions
            of meaning and commitment at work. Published in the <em>Journal of Applied Psychology</em>
            as an Editor's Choice selection.
          </p>
          <div class="press-card-coverage">
            <div class="press-coverage-item">
              <span class="press-coverage-outlet">China Business Knowledge</span>
              <a href="https://cbk.bschool.cuhk.edu.hk/how-motherhood-boosts-work-effort-and-initiatives/" target="_blank" rel="noopener" class="press-coverage-headline">"How motherhood boosts work effort and initiatives"</a>
            </div>
            <div class="press-coverage-item">
              <span class="press-coverage-outlet">UNM News</span>
              <a href="https://news.unm.edu/news/unm-study-challenges-motherhood-penalty-finding-workplace-advantages-for-moms" target="_blank" rel="noopener" class="press-coverage-headline">"UNM study uncovers a 'motherhood advantage' in the workplace"</a>
            </div>
          </div>
        </div>

        <!-- Fast Company -->
        <div class="press-card">
          <span class="press-outlet">Fast Company</span>
          <h3 class="press-card-headline press-card-headline--sm"><a href="https://www.fastcompany.com/90759430/does-being-nice-hurt-your-career" target="_blank" rel="noopener" class="press-title-link">Does being nice hurt your career?</a></h3>
          <p class="press-card-body">
            Research challenging the assumption that kindness and career success are in tension,
            and what the evidence actually shows about nice people in the workplace.
          </p>
        </div>

        <!-- PC TikTok -->
        <div class="press-card">
          <span class="press-outlet">Providence College Business</span>
          <h3 class="press-card-headline press-card-headline--sm"><a href="https://www.tiktok.com/@pcbusinessschool/video/7558853854960422158" target="_blank" rel="noopener" class="press-title-link">Why I teach management</a></h3>
          <p class="press-card-body">
            Featured alongside PC Business faculty discussing their passion for teaching
            and developing the next generation of managers and leaders.
          </p>
        </div>

        <!-- PC News -->
        <div class="press-card">
          <span class="press-outlet">PC News</span>
          <h3 class="press-card-headline press-card-headline--sm"><a href="https://news.providence.edu/national-business-ethics-competition/" target="_blank" rel="noopener" class="press-title-link">Providence College team wins national business ethics competition</a></h3>
          <p class="press-card-body">
            Coverage of PC student teams competing and winning at the national level in
            business ethics, with Dr. Ptashnik involved in preparing and coaching the team.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- ── Contact strip ──────────────────────────────── -->
  <section class="press-contact section">
    <div class="container press-contact-inner">
      <p class="press-contact-text">Press inquiries</p>
      <a href="/contact" class="btn btn-outline">Get in touch</a>
    </div>
  </section>

</Layout>

<style>
  /* ── Hero ─────────────────────────────── */
  .press-hero {
    background: var(--press-dark);
    padding: 7rem 0;
  }

  .press-hero-inner {
    max-width: 820px;
  }

  .press-hero-label {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.45);
    margin-bottom: 2rem;
  }

  .press-hero-quote {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 3.5vw, 2.5rem);
    font-style: italic;
    color: var(--white);
    line-height: 1.4;
    letter-spacing: -0.01em;
    margin-bottom: 2rem;
  }

  .press-hero-attr {
    font-size: 0.82rem;
    color: rgba(255,255,255,0.45);
    letter-spacing: 0.04em;
  }

  /* ── Grid ─────────────────────────────── */
  .press-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    grid-template-rows: auto auto;
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .press-card {
    background: var(--white);
    border: 1px solid var(--border);
    padding: 2.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    transition: border-color 0.2s;
  }

  .press-card:hover {
    border-color: var(--navy);
  }

  /* Featured card spans full width */
  .press-card--featured {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem 3rem;
    border-top: 3px solid var(--navy);
  }

  .press-card--featured .press-card-body {
    grid-column: 1;
  }

  .press-card-outlets {
    grid-column: 1 / -1;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .press-card--featured .press-card-headline {
    grid-column: 1;
    font-size: 1.5rem;
  }

  .press-card-coverage {
    grid-column: 2;
    grid-row: 2 / 4;
    align-self: start;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding-left: 2rem;
    border-left: 1px solid var(--border);
  }

  .press-coverage-item {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .press-coverage-outlet {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--navy);
  }

  .press-coverage-headline {
    font-size: 0.875rem;
    color: var(--dark);
    font-style: italic;
    line-height: 1.5;
    text-decoration: none;
  }

  a.press-coverage-headline:hover {
    color: var(--navy);
    text-decoration: underline;
  }

  .press-title-link {
    color: inherit;
    text-decoration: none;
  }

  .press-title-link:hover {
    color: var(--navy);
    text-decoration: underline;
  }

  /* Shared card elements */
  .press-outlet {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--navy);
  }

  .press-divider {
    color: var(--border);
  }

  .press-card-headline {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    line-height: 1.3;
    color: var(--dark);
  }

  .press-card-headline--sm {
    font-size: 1.1rem;
  }

  .press-card-body {
    font-size: 0.875rem;
    color: var(--muted);
    line-height: 1.75;
  }

  /* ── Contact strip ────────────────────── */
  .press-contact {
    border-top: 1px solid var(--border);
  }

  .press-contact-inner {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .press-contact-text {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
  }

  /* ── Responsive ───────────────────────── */
  @media (max-width: 720px) {
    .press-hero {
      padding: 4rem 0;
    }
    .press-grid {
      grid-template-columns: 1fr;
    }
    .press-card--featured {
      grid-template-columns: 1fr;
    }
    .press-card--featured .press-card-headline,
    .press-card--featured .press-card-body {
      grid-column: 1;
    }
    .press-card-coverage {
      grid-column: 1;
      grid-row: auto;
      border-left: none;
      padding-left: 0;
      border-top: 1px solid var(--border);
      padding-top: 1.25rem;
    }
  }
</style>
