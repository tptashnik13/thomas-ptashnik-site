---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Research" description="Publications, working papers, and research pipeline from Thomas Ptashnik — organizational behavior, well-being, and working parents.">

  <section class="page-header section">
    <div class="container">
      <p class="section-label">Research</p>
      <h1 class="page-title">Organizational Behavior &amp; Well-being</h1>
      <p class="page-subtitle">
        My work examines working parents, employee well-being, and human resource management,
        with a focus on longitudinal methods and meta-analysis.
      </p>
    </div>
  </section>

  <!-- ── Published ─────────────────────────────────── -->
  <section class="section">
    <div class="container research-grid">
      <div class="research-sidebar">
        <h2 class="sidebar-heading">Published</h2>
      </div>
      <ul class="pub-list">

        <li class="pub-item">
          <p class="pub-venue">Journal of Applied Psychology · 2026</p>
          <p class="pub-title">Uncovering A Motherhood Advantage: How Parenthood Impacts Perceptions of the Meaning of Work</p>
          <p class="pub-authors">Huiyao, L., Allen, T., Zhaopeng, L., Ptashnik, T., &amp; Wu, I.</p>
          <span class="pub-badge">Editor's Choice</span>
        </li>

        <li class="pub-item">
          <p class="pub-venue">Psychological Bulletin · 2022</p>
          <p class="pub-title">Feeling good, doing good, and getting ahead: A meta-analytic investigation of the outcomes of prosocial motivation at work</p>
          <p class="pub-authors">Huiyao, L., Su, R., Ptashnik, T., &amp; Nielsen, J.</p>
        </li>

        <li class="pub-item">
          <p class="pub-venue">Oxford Bibliographies in Management · 2019</p>
          <p class="pub-title">Team Design Characteristics</p>
          <p class="pub-authors">Stewart, G. L., Carter, K. M., &amp; Ptashnik, T. (ed. R. W. Griffin)</p>
        </li>

      </ul>
    </div>
  </section>

  <!-- ── Under Review ───────────────────────────────── -->
  <section class="section">
    <div class="container research-grid">
      <div class="research-sidebar">
        <h2 class="sidebar-heading">Under Review</h2>
      </div>
      <ul class="pub-list">

        <li class="pub-item">
          <p class="pub-venue">Personnel Psychology</p>
          <p class="pub-title">Human Resources Management Remote Work Practices</p>
          <p class="pub-authors">Campion, E., Zhu, S., Ptashnik, T., &amp; Campion, M.</p>
        </li>

        <li class="pub-item">
          <p class="pub-venue">Journal of Organizational Behavior</p>
          <p class="pub-title">Leader Identity Threat</p>
          <p class="pub-authors">Nielsen, J., Ptashnik, T., Colbert, A., &amp; Lynch, J.</p>
        </li>

        <li class="pub-item">
          <p class="pub-venue">Management Teaching Review</p>
          <p class="pub-title">Screen Time Self-Reflection Activity</p>
          <p class="pub-authors">Eriksen, M., Ptashnik, T., Choi, W., Srinivasan, A., &amp; Kresser, G.</p>
        </li>

      </ul>
    </div>
  </section>

  <!-- ── Working Papers ────────────────────────────── -->
  <section class="section">
    <div class="container research-grid">
      <div class="research-sidebar">
        <h2 class="sidebar-heading">Working Papers</h2>
      </div>
      <ul class="pub-list">

        <li class="pub-item">
          <p class="pub-venue">Target: Psychological Bulletin</p>
          <p class="pub-title">Meta-Analytic Examination of Well-being Factor Structure</p>
          <p class="pub-authors">Ptashnik, T., Su, R., Jeong, S., Lee, S., &amp; Choi, W.</p>
        </li>

        <li class="pub-item">
          <p class="pub-venue">Target: Journal of Applied Psychology</p>
          <p class="pub-title">Longitudinal reciprocal relationships between career success and goal importance by gender</p>
          <p class="pub-authors">Ptashnik, T., Su, R., &amp; Li, W.</p>
        </li>

        <li class="pub-item">
          <p class="pub-venue">Target: Journal of Applied Psychology</p>
          <p class="pub-title">Mindfulness role in isolation appraisal among teleworkers</p>
          <p class="pub-authors">Lyddy, C., Ptashnik, T., &amp; Good, D.</p>
        </li>

        <li class="pub-item">
          <p class="pub-venue">Target: Academy of Management Discoveries</p>
          <p class="pub-title">Flexplace buffering stressor effects on well-being</p>
          <p class="pub-authors">Livingston, B., Ptashnik, T., Colbert, A., Rohlman, D., &amp; Campo, S.</p>
        </li>

        <li class="pub-item">
          <p class="pub-venue">Target: Journal of Management Education</p>
          <p class="pub-title">Student self-management impact on engagement and learning</p>
          <p class="pub-authors">Eriksen, M. &amp; Ptashnik, T.</p>
        </li>

        <li class="pub-item">
          <p class="pub-venue">Target: Journal of Applied Psychology</p>
          <p class="pub-title">Construal level theory and performance appraisal bias against working mothers</p>
          <p class="pub-authors">Huiyao, L. &amp; Ptashnik, T.</p>
        </li>

        <li class="pub-item">
          <p class="pub-venue">Target: Journal of Applied Psychology</p>
          <p class="pub-title">Employee workplace envy impact on spouse marital satisfaction</p>
          <p class="pub-authors">Wu, I. &amp; Ptashnik, T.</p>
        </li>

      </ul>
    </div>
  </section>

  <!-- ── Conferences ────────────────────────────────── -->
  <section class="section">
    <div class="container research-grid">
      <div class="research-sidebar">
        <h2 class="sidebar-heading">Conferences</h2>
      </div>
      <div class="conf-list">
        <div class="conf-item">
          <span class="conf-venue">Academy of Management</span>
          <span class="conf-years">2024, 2025, 2026</span>
        </div>
        <div class="conf-item">
          <span class="conf-venue">Society for Industrial &amp; Organizational Psychology (SIOP)</span>
          <span class="conf-years">2026</span>
        </div>
        <div class="conf-item">
          <span class="conf-venue">Academy of International Business</span>
          <span class="conf-years">2024</span>
        </div>
        <div class="conf-item">
          <span class="conf-venue">Southern Management Association</span>
          <span class="conf-years">2019</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Collaborate CTA ────────────────────────────── -->
  <section class="collab-section section">
    <div class="container">
      <div class="collab-inner">
        <h2 class="collab-heading">Interested in collaborating?</h2>
        <p class="collab-body">
          I'm always open to conversations about methodology, co-authorship, or data partnerships
          in the areas of well-being, working parents, and organizational behavior.
        </p>
        <a href="mailto:thomasptashnik@gmail.com" class="btn btn-primary">Get in touch</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .page-header {
    border-bottom: 1px solid var(--border);
  }

  .page-title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 3rem);
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }

  .page-subtitle {
    font-size: 1.05rem;
    color: var(--muted);
    max-width: 560px;
    line-height: 1.8;
    font-weight: 300;
  }

  /* ── Two-column research layout ───────── */
  .research-grid {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 4rem;
    align-items: start;
  }

  .sidebar-heading {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    padding-top: 0.2rem;
    position: sticky;
    top: calc(var(--nav-height) + 2rem);
  }

  /* ── Conference list ──────────────────── */
  .conf-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .conf-item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
  }

  .conf-item:last-child {
    border-bottom: none;
  }

  .conf-venue {
    font-size: 0.95rem;
    font-weight: 500;
  }

  .conf-years {
    font-size: 0.8rem;
    color: var(--muted);
    white-space: nowrap;
  }

  /* ── Collab CTA ───────────────────────── */
  .collab-section {
    background: var(--surface);
  }

  .collab-inner {
    max-width: 560px;
  }

  .collab-heading {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    margin-bottom: 0.75rem;
  }

  .collab-body {
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.8;
    margin-bottom: 1.75rem;
  }

  /* ── Responsive ───────────────────────── */
  @media (max-width: 640px) {
    .research-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .sidebar-heading {
      position: static;
      border-bottom: 1px solid var(--border);
      padding-bottom: 0.75rem;
    }
    .conf-item {
      flex-direction: column;
      gap: 0.25rem;
    }
  }
</style>
