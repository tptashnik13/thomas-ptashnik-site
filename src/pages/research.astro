---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Research" description="Publications, working papers, and research pipeline from Thomas Ptashnik — organizational behavior, well-being, and working parents.">

  <section class="page-header section">
    <div class="container">
      <p class="section-label">Research</p>
      <h1 class="page-title">Work, Family, and Well-being</h1>
      <p class="page-subtitle">
        My work sits at the intersection of organizational behavior and HRM, spanning
        work–family dynamics, HR systems, and employee well-being — with prosocial motivation
        and communal orientation as a connecting thread.
      </p>
    </div>
  </section>

  <!-- ── Published ─────────────────────────────────── -->
  <section class="section">
    <div class="container research-grid">
      <div class="research-sidebar">
        <h2 class="sidebar-heading">Published</h2>
      </div>
      <ul class="pub-list">

        <li class="pub-item">
          <p class="pub-venue">Journal of Applied Psychology · 2026</p>
          <a class="pub-title pub-link" href="https://doi.org/10.1037/apl0001355" target="_blank" rel="noopener">Uncovering A Motherhood Advantage: How Parenthood Impacts Perceptions of the Meaning of Work and Work Outcomes</a>
          <p class="pub-authors">Liao, H., Allen, T., Liu, Z., <strong>Ptashnik, T.</strong>, &amp; Wu, I.</p>
          <span class="pub-badge">APA Editor's Choice</span>
        </li>

        <li class="pub-item">
          <p class="pub-venue">Psychological Bulletin · 2022</p>
          <a class="pub-title pub-link" href="https://doi.org/10.1037/bul0000362" target="_blank" rel="noopener">Feeling good, doing good, and getting ahead: A meta-analytic investigation of the outcomes of prosocial motivation at work</a>
          <p class="pub-authors">Liao, H., Su, R., <strong>Ptashnik, T.</strong>, &amp; Nielsen, J.</p>
        </li>

        <li class="pub-item">
          <p class="pub-venue">Oxford Bibliographies in Management · 2019</p>
          <a class="pub-title pub-link" href="https://academic.oup.com/reference/62383/reference-article-abstract/561732761?redirectedFrom=fulltext" target="_blank" rel="noopener">Team Design Characteristics</a>
          <p class="pub-authors">Stewart, G. L., Carter, K. M., &amp; <strong>Ptashnik, T.</strong> (ed. R. W. Griffin)</p>
        </li>

      </ul>
    </div>
  </section>

  <!-- ── Under Review ───────────────────────────────── -->
  <section class="section">
    <div class="container research-grid">
      <div class="research-sidebar">
        <h2 class="sidebar-heading">Under Review</h2>
      </div>
      <ul class="pub-list">

        <li class="pub-item">
          <p class="pub-venue">Personnel Psychology · R&amp;R</p>
          <p class="pub-title">HRM practices empowering remote and hybrid workers</p>
          <p class="pub-authors">Campion, E., Zhu, X., <strong>Ptashnik, T.</strong>, Campion, M., &amp; Alonso, A.</p>
          <span class="pub-badge">First Round R&amp;R</span>
        </li>

        <li class="pub-item">
          <p class="pub-venue">Journal of Applied Psychology</p>
          <p class="pub-title">Does success spawn greed or generosity? Longitudinal reciprocal relationships between income and agentic versus communal goals</p>
          <p class="pub-authors"><strong>Ptashnik, T.</strong>, Su, R., &amp; Li, W.</p>
        </li>

        <li class="pub-item">
          <p class="pub-venue">Journal of Personality and Social Psychology</p>
          <p class="pub-title">A meta-analytic examination of the factor structure of well-being</p>
          <p class="pub-authors"><strong>Ptashnik, T.</strong>, Su, R., Jeong, S., Lee, S., &amp; Choi, W.</p>
        </li>

        <li class="pub-item">
          <p class="pub-venue">Journal of Occupational and Organizational Psychology</p>
          <p class="pub-title">Leader identity threat</p>
          <p class="pub-authors">Nielsen, J., <strong>Ptashnik, T.</strong>, Colbert, A., &amp; Lynch, J.</p>
        </li>

        <li class="pub-item">
          <p class="pub-venue">Management Teaching Review</p>
          <p class="pub-title">Screen time intervention for college students</p>
          <p class="pub-authors">Eriksen, M., <strong>Ptashnik, T.</strong>, Choi, W., Srinivasan, A., &amp; Kresser, G.</p>
        </li>

      </ul>
    </div>
  </section>

  <!-- ── Research in Progress ──────────────────────── -->
  <section class="section">
    <div class="container research-grid">
      <div class="research-sidebar">
        <h2 class="sidebar-heading">In Progress</h2>
      </div>
      <ul class="pub-list">

        <li class="pub-item">
          <p class="pub-venue">Target: Journal of Applied Psychology</p>
          <p class="pub-title">Construal level theory and performance appraisal bias against working mothers</p>
          <p class="pub-authors"><strong>Ptashnik, T.</strong>, Liao, H., &amp; Wu, I.</p>
        </li>

        <li class="pub-item">
          <p class="pub-venue">Target: Journal of Applied Psychology</p>
          <p class="pub-title">The influence of religiosity and SES on legacy motivation</p>
          <p class="pub-authors"><strong>Ptashnik, T.</strong> &amp; Liao, H.</p>
        </li>

        <li class="pub-item">
          <p class="pub-venue">Target: Journal of Management</p>
          <p class="pub-title">Aspiring parents: A systematic review</p>
          <p class="pub-authors"><strong>Ptashnik, T.</strong></p>
        </li>

        <li class="pub-item">
          <p class="pub-venue">Target: California Management Review</p>
          <p class="pub-title">Why employers should not undervalue working mothers</p>
          <p class="pub-authors"><strong>Ptashnik, T.</strong>, Liao, H., Allen, T., &amp; Liu, Z.</p>
        </li>

        <li class="pub-item">
          <p class="pub-venue">Target: Journal of Organizational Behavior</p>
          <p class="pub-title">The role of mindfulness shaping the appraisal of isolation among solitary teleworkers</p>
          <p class="pub-authors">Lyddy, C., Good, D., &amp; <strong>Ptashnik, T.</strong></p>
        </li>

        <li class="pub-item">
          <p class="pub-venue">Target: Academy of Management Learning &amp; Education</p>
          <p class="pub-title">Self-awareness and self-management activity</p>
          <p class="pub-authors">Eriksen, M., <strong>Ptashnik, T.</strong>, Choi, W., &amp; Srinivasan, A.</p>
        </li>

      </ul>
    </div>
  </section>

  <!-- ── Conferences ────────────────────────────────── -->
  <section class="section">
    <div class="container research-grid">
      <div class="research-sidebar">
        <h2 class="sidebar-heading">Conferences</h2>
      </div>
      <div class="conf-list">

        <div class="conf-item">
          <div class="conf-main">
            <span class="conf-venue">Academy of Management</span>
            <span class="conf-award">Best Convention Paper Award · Human Resources Division</span>
          </div>
          <span class="conf-years">2019, 2020, 2022, 2024, 2025, 2026</span>
        </div>

        <div class="conf-item">
          <div class="conf-main">
            <span class="conf-venue">Society for Industrial &amp; Organizational Psychology (SIOP)</span>
            <span class="conf-award">Top-rated poster · Organizational Processes Track</span>
          </div>
          <span class="conf-years">2026</span>
        </div>

        <div class="conf-item">
          <div class="conf-main">
            <span class="conf-venue">Academy of International Business</span>
          </div>
          <span class="conf-years">2024</span>
        </div>

        <div class="conf-item">
          <div class="conf-main">
            <span class="conf-venue">Western Academy of Management</span>
          </div>
          <span class="conf-years">2022</span>
        </div>

        <div class="conf-item">
          <div class="conf-main">
            <span class="conf-venue">Southern Management Association</span>
          </div>
          <span class="conf-years">2019</span>
        </div>

      </div>
    </div>
  </section>

  <!-- ── Collaborate CTA ────────────────────────────── -->
  <section class="collab-section section">
    <div class="container">
      <div class="collab-inner">
        <h2 class="collab-heading">Interested in collaborating?</h2>
        <p class="collab-body">
          I'm always open to conversations about methodology, co-authorship, or data partnerships
          in the areas of well-being, working parents, and organizational behavior.
        </p>
        <a href="/contact" class="btn btn-primary">Get in touch</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .page-header {
    border-bottom: 1px solid var(--border);
  }

  .page-title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 3rem);
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }

  .page-subtitle {
    font-size: 1.05rem;
    color: var(--muted);
    max-width: 600px;
    line-height: 1.8;
    font-weight: 300;
  }

  /* ── Pub link ────────────────────────── */
  .pub-link {
    display: block;
    color: var(--dark);
    text-decoration: none;
    transition: color 0.15s;
  }

  .pub-link:hover {
    color: var(--navy);
    text-decoration: underline;
  }

  /* ── Two-column research layout ───────── */
  .research-grid {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 4rem;
    align-items: start;
  }

  .sidebar-heading {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    padding-top: 0.2rem;
    position: sticky;
    top: calc(var(--nav-height) + 2rem);
  }

  /* ── Conference list ──────────────────── */
  .conf-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .conf-item {
    display: flex;
    justify-content: space-between;
    align-items: start;
    gap: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
  }

  .conf-item:last-child {
    border-bottom: none;
  }

  .conf-main {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .conf-venue {
    font-size: 0.95rem;
    font-weight: 500;
  }

  .conf-award {
    font-size: 0.78rem;
    color: var(--navy);
    font-weight: 500;
  }

  .conf-years {
    font-size: 0.8rem;
    color: var(--muted);
    white-space: nowrap;
    padding-top: 0.15rem;
  }

  /* ── Collab CTA ───────────────────────── */
  .collab-section {
    background: var(--surface);
  }

  .collab-inner {
    max-width: 560px;
  }

  .collab-heading {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    margin-bottom: 0.75rem;
  }

  .collab-body {
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.8;
    margin-bottom: 1.75rem;
  }

  /* ── Responsive ───────────────────────── */
  @media (max-width: 640px) {
    .research-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .sidebar-heading {
      position: static;
      border-bottom: 1px solid var(--border);
      padding-bottom: 0.75rem;
    }
    .conf-item {
      flex-direction: column;
      gap: 0.25rem;
    }
  }
</style>
